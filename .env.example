# Copy this file to .env and fill in your real values.
# NEVER commit your actual .env file or share your private key.

# Your MetaMask wallet's private key (without the 0x prefix).
# Get it from: MetaMask -> Account Details -> Show Private Key
# This wallet needs testnet MON from the faucet to pay gas.
PRIVATE_KEY=

# OpenAI API key (if using GPT for the agent)
OPENAI_API_KEY=

# Anthropic API key (if using Claude for the agent instead)
ANTHROPIC_API_KEY=

# Filled in automatically after you run the deploy script — paste
# the deployed contract address here so the agent/server can use it.
CONTRACT_ADDRESS=
